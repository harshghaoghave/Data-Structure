#include <stdlib.h>

#define MAX 100

// Node structure
struct Node {
    int data;
    struct Node* next;
};

// Global arrays
struct Node* adjList[MAX];
int visited[MAX];

// Create node
struct Node* createNode(int v) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = v;
    newNode->next = NULL;
    return newNode;
}

// Add edge (directed graph)
void addEdge(int u, int v) {
    struct Node* newNode = createNode(v);

    if (adjList[u] == NULL || v < adjList[u]->data) {
        newNode->next = adjList[u];
        adjList[u] = newNode;
    } else {
        struct Node* curr = adjList[u];
        while (curr->next != NULL && curr->next->data < v) {
            curr = curr->next;
        }
        newNode->next = curr->next;
        curr->next = newNode;
    }
}

// DFS
void DFS(int start) {
    visited[start] = 1;
    printf("%d ", start);

    struct Node* temp = adjList[start];

    while (temp != NULL) {
        int v = temp->data;
        if (!visited[v]) {
            DFS(v);
        }
        temp = temp->next;
    }
}

int main() {
    int V, E;
    int u, v, start;

    scanf("%d %d", &V, &E);

    for (int i = 0; i < V; i++) {
        adjList[i] = NULL;
        visited[i] = 0;
    }

    for (int i = 0; i < E; i++) {
        scanf("%d %d", &u, &v);
        addEdge(u, v);  // Directed graph
    }

    scanf("%d", &start);

    DFS(start);

    return 0;
}
